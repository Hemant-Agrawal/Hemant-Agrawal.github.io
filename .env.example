# EmailJS — get these at https://dashboard.emailjs.com
# Copy to .env.local and fill in. All three are public client keys.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Google Tag Manager — https://tagmanager.google.com
# Format: GTM-XXXXXXX. Leave blank to disable analytics in dev.
NEXT_PUBLIC_GTM_ID=

# Google Search Console — verification token only (the content="..." value).
# Get it: search.google.com/search-console → add property → HTML tag method.
NEXT_PUBLIC_GSC_VERIFICATION=
